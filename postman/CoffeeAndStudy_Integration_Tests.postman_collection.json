      "name": "01 Create Category - 201",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const json = pm.response.json();\r",
              "\r",
              "pm.test(\"Response has correct structure\", function () {\r",
              "    pm.expect(json).to.have.property(\"id\");\r",
              "    pm.expect(json).to.have.property(\"name\");\r",
              "    pm.expect(json).to.have.property(\"description\");\r",
              "    pm.expect(json).to.have.property(\"colorHex\");\r",
              "    pm.expect(json).to.have.property(\"priority\");\r",
              "    pm.expect(json).to.have.property(\"active\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response values are correct\", function () {\r",
              "    pm.expect(json.name).to.eql(\"Postman Cafe\");\r",
              "    pm.expect(json.description).to.eql(\"Categoria creada desde Postman\");\r",
              "    pm.expect(json.colorHex).to.eql(\"#AABBCC\");\r",
              "    pm.expect(json.priority).to.eql(1);\r",
              "    pm.expect(json.active).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.environment.set(\"categoryId\", json.id);\r",
              "pm.collectionVariables.set(\"categoryId\", json.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
